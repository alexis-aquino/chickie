# Supabase project settings -> Database -> Connection string.
# Local dev: the direct "URI" connection works.
# Vercel/serverless: use the Supavisor pooler URI instead (aws-…pooler.supabase.com) —
# the direct host is IPv6-only, which serverless platforms may not reach.
# Any postgres:// / postgresql:// prefix is fine; the app forces the psycopg3 driver.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase project settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=

# Origin the Vite dev server runs on, so the browser is allowed to call this API
CORS_ORIGIN=http://localhost:5173
