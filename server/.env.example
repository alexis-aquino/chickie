# Supabase project settings -> Database -> Connection string (use the "URI" / direct connection, not the pooler transaction mode)
DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase project settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=

# Origin the Vite dev server runs on, so the browser is allowed to call this API
CORS_ORIGIN=http://localhost:5173
