# Local MySQL connection — create the database and load server/schema.sql first:
#   mysql -u root -p -e "CREATE DATABASE chickie"
#   mysql -u root -p chickie < server/schema.sql
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/chickie

# Secret used to sign/verify this backend's own JWTs. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=

# Origin the Vite dev server runs on, so the browser is allowed to call this API
CORS_ORIGIN=http://localhost:5173
